{
  "name": "erp-api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prestart": "node --max-old-space-size=512 --optimize-for-size -r ts-node/register -r tsconfig-paths/register src/seed/seedAdmin.ts",
    "prestart:dev": "node --max-old-space-size=512 --optimize-for-size -r ts-node/register -r tsconfig-paths/register src/seed/seedAdmin.ts",
    "prestart:prod": "node --max-old-space-size=512 --optimize-for-size dist/src/seed/seedAdmin.js",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "seed-sys": "node --max-old-space-size=512 --optimize-for-size -r ts-node/register -r tsconfig-paths/register src/seed/seedAdmin.ts",
    "start": "node --max-old-space-size=768 --optimize-for-size node_modules/@nestjs/cli/bin/nest.js start",
    "start:dev": "node --max-old-space-size=768 --optimize-for-size node_modules/@nestjs/cli/bin/nest.js start --watch",
    "start:debug": "node --max-old-space-size=768 --optimize-for-size node_modules/@nestjs/cli/bin/nest.js start --debug --watch",
    "start:prod": "node --max-old-space-size=768 --optimize-for-size dist/main",
    "start:optimized": "bash scripts/start-optimized.sh",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mongoose": "^10.0.4",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/swagger": "^7.3.0",
    "@nestjs/throttler": "^5.1.2",
    "bcrypt": "^5.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "date-fns": "^4.1.0",
    "epub-gen": "^0.1.0",
    "firebase-admin": "^13.5.0",
    "mongoose": "^7.3.0",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "pdf-parse": "^1.1.1",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@types/bcrypt": "^5.0.0",
    "@types/express": "^4.17.23",
    "@types/glob": "^9.0.0",
    "@types/jest": "29.5.1",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.11.0",
    "@types/passport-jwt": "^3.0.8",
    "@types/pdf-parse": "^1.1.5",
    "@types/supertest": "^2.0.11",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^4.0.0",
    "globals": "^16.4.0",
    "jest": "29.5.0",
    "lefthook": "^1.13.6",
    "lint-staged": "^16.2.4",
    "prettier": "^3.6.2",
    "source-map-support": "^0.5.20",
    "supertest": "^6.1.3",
    "ts-jest": "29.1.0",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.46.1"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
